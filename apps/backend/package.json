{
  "name": "@virtual-try-on/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx bin/server.ts",
    "build": "tsc",
    "start": "node bin/server.js",
    "type-check": "tsc --noEmit"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#models/*": "./app/models/*.js",
    "#types/*": "./app/types/*.js",
    "#config/*": "./config/*.js",
    "#start/*": "./start/*.js"
  },
  "dependencies": {
    "@adonisjs/auth": "^9.6.0",
    "@adonisjs/core": "^6.20.0",
    "@adonisjs/cors": "^2.2.1",
    "@adonisjs/lucid": "^21.8.2",
    "@vinejs/vine": "^2.1.0",
    "luxon": "^3.7.2",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.2",
    "@adonisjs/tsconfig": "^1.4.1",
    "@swc/core": "^1.7.26",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.5.4",
    "@types/pg": "^8.16.0",
    "hot-hook": "^0.3.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  }
}
