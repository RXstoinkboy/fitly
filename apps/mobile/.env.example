# Backend API URL (no trailing slash).
# Use your machine's LAN IP address when running on a physical device —
# "localhost" on a real device refers to the device itself, not your dev machine.
# Examples:
#   iOS Simulator / Android Emulator: http://localhost:3333
#   Physical device (LAN):            http://192.168.1.x:3333
EXPO_PUBLIC_API_URL=

# Optional: API key to authenticate with the backend (must match backend API_KEY).
# Leave empty if the backend has no API_KEY set.
EXPO_PUBLIC_API_KEY=

# RevenueCat configuration (placeholder values until real keys are provided)
EXPO_PUBLIC_REVENUECAT_API_KEY=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=pro
EXPO_PUBLIC_REVENUECAT_OFFERING_ID=
